---
import Layout from '../layouts/Layout.astro';
import profile_1 from '../assets/profile_1.webp';
---

<Layout>
	<div class="container mx-auto px-4 py-8 md:max-w-5xl">
		<div class="max-w-4xl mx-auto">

			<!-- Two-column layout: text left, image right -->
			<div class="flex flex-col-reverse md:flex-row md:items-start gap-8 md:gap-12 mb-12">

				<!-- Text content -->
				<div class="flex-1">
					<h1 class="text-3xl font-bold text-[var(--color-text-primary)] mb-8">About Me</h1>

					<p class="text-lg text-[var(--color-text-primary)] leading-relaxed mb-6">
						My name is Andy Hardy and I'm the founder of Ultimate Question Coding LLC.  I live in Waterbury VT with my wife Katie.
					</p>
					<p class="text-lg text-[var(--color-text-primary)] leading-relaxed mb-6">
						I'm a software developer with six years of experience building thoughtful, real-world technology — especially in IoT, mapping, and pragmatic applications of AI (the kind that solve problems, not just sell buzzwords).
					</p>
					<p class="text-lg text-[var(--color-text-primary)] leading-relaxed mb-6">
						Before software, I spent a decade as a chemist, with a ski-bum intermission out West. I've lived most of my life in New England, aside from a few years in Colorado and a brief Alaskan beginning.
					</p>
					<p class="text-lg text-[var(--color-text-primary)] leading-relaxed">
						When I get stuck on a hard problem, I usually find the answer by riding or skiing through the woods — it's often the jolt of movement, not the keyboard, that knocks it loose.
					</p>
				</div>

				<!-- Profile image -->
				<div class="flex-shrink-0 mx-auto md:mx-0">
					<div class="h-[50vw] w-[50vw] md:h-[280px] md:w-[280px] lg:h-[340px] lg:w-[340px] border-3 border-[var(--color-card)] rounded-full overflow-hidden">
						<img src={profile_1.src} alt="Profile" class="w-full h-full object-cover" />
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>
